# Ignore development files but keep src/ for building
.env
.env.local
.env.development
.env.test
build.sh
deploy.sh
deploy.log

# Ignore version control
.git/
.github/
.gitignore

# Ignore backup and temp files
legacy_backup/
*.backup
*~
*.tmp

# Ignore test files
test/
tests/
__tests__/
*.test.*
*.spec.*

# Ignore development dependencies that aren't needed
node_modules/.cache/
.nyc_output/
coverage/

# Ignore editor files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore installed dependencies; keep lockfile so Cloud Build matches local resolution
node_modules/

# Ignore data directories (not needed for production - BigQuery is the source)
data/
logs/
scripts/__pycache__/
